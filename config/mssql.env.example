# Copy this file to config/mssql.env on the school intranet machine.
# Never commit the real config/mssql.env file.

ALPHA_MSSQL_HOST=your.sqlserver.host
ALPHA_MSSQL_PORT=1433
ALPHA_MSSQL_DATABASE=your_database_name
ALPHA_MSSQL_USER=your_username
ALPHA_MSSQL_PASSWORD='your_password'
ALPHA_MSSQL_DRIVER='ODBC Driver 18 for SQL Server'
ALPHA_MSSQL_ENCRYPT=no
ALPHA_MSSQL_TRUST_SERVER_CERTIFICATE=yes
ALPHA_MSSQL_TIMEOUT=10
